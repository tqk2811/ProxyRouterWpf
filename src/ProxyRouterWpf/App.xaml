<Application x:Class="ProxyRouterWpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ProxyRouterWpf.Converters"
             xmlns:loc="clr-namespace:ProxyRouterWpf.Localization">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Swappable palette (index 0). Default Dark; replaced at startup / toggle by ThemeManager. -->
                <ResourceDictionary Source="Themes/Colors.Dark.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
                <!-- Swappable strings. Default English; replaced at startup / toggle by LocalizationManager. -->
                <ResourceDictionary Source="Localization/Strings.en.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <loc:EnumLocalizeConverter x:Key="EnumLoc"/>
            <loc:AppLanguageDisplayConverter x:Key="LangDisplay"/>

            <conv:BytesConverter x:Key="Bytes"/>
            <conv:RateConverter x:Key="Rate"/>
            <conv:DashConverter x:Key="Dash"/>
            <conv:LocalTimeConverter x:Key="LocalTime"/>
            <conv:OutcomeBrushConverter x:Key="OutcomeBrush"/>
            <conv:ClientProtocolBrushConverter x:Key="ProtocolBrush"/>
            <conv:ProxyTypeBrushConverter x:Key="ProxyTypeBrush"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisInverse" Invert="True"/>
            <conv:NullOrEmptyToVisibilityConverter x:Key="NotEmptyToVis"/>
            <conv:NullOrEmptyToVisibilityConverter x:Key="EmptyToVis" Invert="True"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
