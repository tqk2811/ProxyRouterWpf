<Window x:Class="ProxyRouterWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ProxyRouterWpf.Views"
        Title="ProxyRouter" Height="800" Width="1240" MinHeight="640" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Window.Background}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        TextOptions.TextFormattingMode="Display">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <!-- ===== TabControl with the tab strip hosted in the title bar ===== -->
        <TabControl x:Name="MainTabs" SelectedIndex="{Binding SelectedTabIndex}">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Title bar: app name + tab headers + (reserved space for window buttons) -->
                        <Grid Grid.Row="0" Background="{DynamicResource Brush.TitleBar.Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="336"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ProxyRouter" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center" Margin="16,0,18,0"/>
                            <TabPanel Grid.Column="1" IsItemsHost="True" VerticalAlignment="Center"
                                      HorizontalAlignment="Left" Margin="0"
                                      WindowChrome.IsHitTestVisibleInChrome="True"/>
                        </Grid>

                        <!-- Selected tab content -->
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="16,10,16,16"/>
                    </Grid>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem Header="{DynamicResource Str.Tab.Proxies}">
                <views:ProxiesView DataContext="{Binding Proxies}"/>
            </TabItem>
            <TabItem Header="{DynamicResource Str.Tab.Logs}">
                <views:LogsView DataContext="{Binding Logs}"/>
            </TabItem>
            <TabItem Header="{DynamicResource Str.Tab.Bandwidth}">
                <views:BandwidthView DataContext="{Binding Bandwidth}"/>
            </TabItem>
        </TabControl>

        <!-- ===== Window controls (overlaid top-right, on top of the title bar) ===== -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right"
                    Height="44" WindowChrome.IsHitTestVisibleInChrome="True">
            <ComboBox Width="140" Height="26" VerticalAlignment="Center" Margin="0,0,8,0"
                      ItemsSource="{Binding Settings.LanguageOptions}"
                      SelectedItem="{Binding Settings.SelectedLanguage}"
                      ToolTip="{DynamicResource Str.Settings.Language}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource LangDisplay}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Style="{StaticResource IconButton}" Width="40" Height="40" Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    Command="{Binding ToggleThemeCommand}" ToolTip="{Binding ThemeTooltip}">
                <TextBlock Text="{Binding ThemeGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="15"/>
            </Button>
            <Button Style="{StaticResource WindowControlButton}" Click="Minimize_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE921;" FontSize="10"/>
            </Button>
            <Button Style="{StaticResource WindowControlButton}" Click="Maximize_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE922;" FontSize="10"/>
            </Button>
            <Button Style="{StaticResource WindowCloseButton}" Click="Close_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8BB;" FontSize="10"/>
            </Button>
        </StackPanel>
    </Grid>
</Window>
