<UserControl x:Class="ProxyRouterWpf.Views.ProxiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ProxyRouterWpf.ViewModels"
             d:DataContext="{d:DesignInstance vm:ProxiesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Right-click on a row selects it so the context menu acts on that row. -->
        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="Row_PreviewMouseRightButtonDown"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== SERVER CONTROL CARD ===================== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <!-- config -->
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Style="{StaticResource Heading}" Text="Máy chủ Proxy"/>
                    <WrapPanel Margin="0,10,0,0">
                        <StackPanel Margin="0,0,16,10" Width="110">
                            <Label Content="Start Port"/>
                            <TextBox Text="{Binding StartPort, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10" Width="150">
                            <Label Content="Địa chỉ lắng nghe"/>
                            <ComboBox ItemsSource="{Binding ListenAddresses}" SelectedItem="{Binding ListenAddress}"
                                      IsEnabled="{Binding CanEdit}" ToolTip="IP mà listener bind vào (0.0.0.0 = mọi interface)"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10" Width="150">
                            <Label Content="Proxy Username"/>
                            <TextBox Text="{Binding ProxyUserName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10" Width="150">
                            <Label Content="Proxy Password"/>
                            <TextBox Text="{Binding ProxyPassword, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10" Width="150">
                            <Label Content="SOCKS4 UserId"/>
                            <TextBox Text="{Binding ProxySocks4UserId, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <CheckBox Content="HTTP" IsChecked="{Binding IsHttpEnabled}" IsEnabled="{Binding CanEdit}" Margin="0,0,18,0"/>
                        <CheckBox Content="SOCKS4" IsChecked="{Binding IsSocks4Enabled}" IsEnabled="{Binding CanEdit}" Margin="0,0,18,0"/>
                        <CheckBox Content="SOCKS5" IsChecked="{Binding IsSocks5Enabled}" IsEnabled="{Binding CanEdit}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Style="{StaticResource AccentButton}" Command="{Binding ToggleCommand}" MinWidth="150">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Bật Proxy"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="Dừng Proxy"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Content="Lưu cấu hình" Command="{Binding SaveConfigureCommand}" IsEnabled="{Binding CanEdit}" Margin="10,0,0,0"/>
                        <Border CornerRadius="6" Padding="10,4" Margin="14,0,0,0" VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Accent.Subtle}">
                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="{DynamicResource Brush.Surface.BorderBrush}" Margin="0,4"/>

                <!-- output -->
                <DockPanel Grid.Column="2" Margin="18,0,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource Heading}" FontSize="14" Text="Proxy Output"/>
                        <ComboBox Width="120" Height="28" Margin="10,0,0,0" SelectedValuePath="Tag"
                                  SelectedValue="{Binding OutputFormat}">
                            <ComboBoxItem Content="http/socks5" Tag="http_socks5"/>
                            <ComboBoxItem Content="socks4" Tag="socks4"/>
                        </ComboBox>
                        <Button Content="Copy" Command="{Binding CopyOutputCommand}" Margin="8,0,0,0" Height="28"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,6,0,4">
                        <TextBlock Text="IP:" Style="{StaticResource Subtle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Width="200" Height="28" ItemsSource="{Binding LocalIps}" SelectedItem="{Binding SelectedIp}"
                                  ToolTip="IP dùng để dựng danh sách proxy output"/>
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Padding="8" Background="{DynamicResource Brush.Surface.Alt}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding OutputPreview, Mode=OneWay}" IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent" FontFamily="Consolas" TextWrapping="NoWrap"/>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ===================== BODY ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Ungrouped proxies -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Heading}" FontSize="14" Margin="0,0,0,10"
                               Text="Proxy nguồn (Ungrouped) — chuột phải để thao tác" VerticalAlignment="Center"/>
                    <DataGrid x:Name="UngroupedGrid" ItemsSource="{Binding UngroupedSources}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Thêm proxy…" Click="AddUngrouped_Click"/>
                                <MenuItem Header="Sửa" Click="EditUngrouped_Click"/>
                                <MenuItem Header="Gán nhóm…" Click="AssignUngrouped_Click"/>
                                <MenuItem Header="Xoá" Click="DeleteUngrouped_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Proxy" Binding="{Binding Display}" Width="*"/>
                            <DataGridTextColumn Header="Loại" Binding="{Binding ProxyTypeText}" Width="70"/>
                            <DataGridTemplateColumn Header="" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Log" Height="24" Padding="10,0" Click="LogForRow_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Groups + detail: two cards, each takes half the height -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Groups -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Heading}" FontSize="14" Margin="0,0,0,10"
                                   Text="Nhóm định tuyến — chuột phải để thao tác" VerticalAlignment="Center"/>
                        <DataGrid x:Name="GroupsGrid" ItemsSource="{Binding Groups}" SelectionMode="Single"
                                  SelectedItem="{Binding SelectedGroup}">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Thêm nhóm…" Click="AddGroup_Click"/>
                                    <MenuItem Header="Sửa" Click="EditGroup_Click"/>
                                    <MenuItem Header="Lên (ưu tiên hơn)" Click="GroupUp_Click"/>
                                    <MenuItem Header="Xuống" Click="GroupDown_Click"/>
                                    <MenuItem Header="Xoá" Click="DeleteGroup_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Ưu tiên" Binding="{Binding Priority}" Width="60"/>
                                <DataGridTemplateColumn Header="Match" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Height="26" SelectedItem="{Binding MatchMode, Mode=OneWay}"
                                                      SelectionChanged="MatchMode_Changed"
                                                      ItemsSource="{Binding DataContext.MatchModeValues, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Nội dung" Binding="{Binding Summary}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Detail (filters + group proxies) -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Heading}" FontSize="14" Margin="0,0,0,8"
                                   Text="{Binding SelectedGroup.Name, StringFormat='Group: {0}', TargetNullValue='Chọn một nhóm'}"/>
                        <TabControl>
                            <TabItem Header="Filters">
                                <DockPanel Margin="0,8,0,0">
                                    <DataGrid x:Name="FiltersGrid" ItemsSource="{Binding Filters}" SelectionMode="Single">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Thêm filter…" Click="AddFilter_Click"/>
                                                <MenuItem Header="Sửa" Click="EditFilter_Click"/>
                                                <MenuItem Header="Xoá" Click="DeleteFilter_Click"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Loại" Binding="{Binding TypeText}" Width="Auto"/>
                                            <DataGridTextColumn Header="Filter" Binding="{Binding Display}" Width="*"/>
                                            <DataGridTemplateColumn Header="NOT" Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsNot, Mode=OneWay}" Click="FilterIsNot_Click" HorizontalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Proxy trong nhóm">
                                <DockPanel Margin="0,8,0,0">
                                    <DataGrid x:Name="GroupSourcesGrid" ItemsSource="{Binding GroupSources}">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Thêm proxy…" Click="AddGroupSource_Click"/>
                                                <MenuItem Header="Bỏ khỏi nhóm" Click="UngroupSource_Click"/>
                                                <MenuItem Header="Xoá" Click="DeleteGroupSource_Click"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Proxy" Binding="{Binding Display}" Width="*"/>
                                            <DataGridTextColumn Header="Loại" Binding="{Binding ProxyTypeText}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
