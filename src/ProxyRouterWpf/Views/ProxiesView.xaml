<UserControl x:Class="ProxyRouterWpf.Views.ProxiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ProxyRouterWpf.ViewModels"
             d:DataContext="{d:DesignInstance vm:ProxiesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Right-click on a row selects it so the context menu acts on that row. -->
        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="Row_PreviewMouseRightButtonDown"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== SERVER CONTROL CARD ===================== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- config -->
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Style="{StaticResource Heading}" Text="{DynamicResource Str.Proxies.ServerTitle}"/>
                    <WrapPanel Margin="0,8,0,0">
                        <StackPanel Margin="0,0,14,6" Width="110">
                            <Label Content="{DynamicResource Str.Proxies.StartPort}"/>
                            <TextBox Text="{Binding StartPort, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,6" Width="150">
                            <Label Content="{DynamicResource Str.Proxies.ListenAddress}"/>
                            <ComboBox ItemsSource="{Binding ListenAddresses}" SelectedItem="{Binding ListenAddress}"
                                      IsEnabled="{Binding CanEdit}" ToolTip="{DynamicResource Str.Proxies.ListenAddressTip}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,6" Width="150">
                            <Label Content="{DynamicResource Str.Proxies.ProxyUsername}"/>
                            <TextBox Text="{Binding ProxyUserName, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,6" Width="150">
                            <Label Content="{DynamicResource Str.Proxies.ProxyPassword}"/>
                            <TextBox Text="{Binding ProxyPassword, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,14,6" Width="150">
                            <Label Content="{DynamicResource Str.Proxies.Socks4UserId}"/>
                            <TextBox Text="{Binding ProxySocks4UserId, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanEdit}"/>
                        </StackPanel>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox Content="HTTP" IsChecked="{Binding IsHttpEnabled}" IsEnabled="{Binding CanEdit}" VerticalAlignment="Center" Margin="0,0,18,0"/>
                        <CheckBox Content="SOCKS4" IsChecked="{Binding IsSocks4Enabled}" IsEnabled="{Binding CanEdit}" VerticalAlignment="Center" Margin="0,0,18,0"/>
                        <CheckBox Content="SOCKS5" IsChecked="{Binding IsSocks5Enabled}" IsEnabled="{Binding CanEdit}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                        <Button Style="{StaticResource AccentButton}" Command="{Binding ToggleCommand}" MinWidth="150">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Str.Proxies.Start}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Str.Proxies.Stop}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                        <Button Content="{DynamicResource Str.Proxies.SaveConfig}" Command="{Binding SaveConfigureCommand}" IsEnabled="{Binding CanEdit}" Margin="10,0,0,0"/>
                        <Border CornerRadius="6" Padding="10,4" Margin="14,0,0,0" VerticalAlignment="Center"
                                Background="{DynamicResource Brush.Accent.Subtle}">
                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Width="1" Background="{DynamicResource Brush.Surface.BorderBrush}" Margin="0,4"/>

                <!-- output -->
                <StackPanel Grid.Column="2" Margin="18,0,0,0">
                    <TextBlock Style="{StaticResource Heading}" FontSize="14" Text="{DynamicResource Str.Proxies.Output}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Format:" Style="{StaticResource Subtle}"
                                   VerticalAlignment="Center" Margin="0,0,8,8"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Height="28" Margin="0,0,0,8" SelectedValuePath="Tag"
                                  SelectedValue="{Binding OutputFormat}">
                            <ComboBoxItem Content="http/socks5" Tag="http_socks5"/>
                            <ComboBoxItem Content="socks4" Tag="socks4"/>
                        </ComboBox>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="IP:" Style="{StaticResource Subtle}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" Height="28" ItemsSource="{Binding LocalIps}"
                                  SelectedItem="{Binding SelectedIp}" ToolTip="{DynamicResource Str.Proxies.OutputIpTip}"/>
                    </Grid>
                    <Button Content="{DynamicResource Str.Common.Copy}" Command="{Binding CopyOutputCommand}"
                            HorizontalAlignment="Left" MinWidth="90" Height="28" Margin="0,12,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== BODY ===================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Ungrouped proxies -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Heading}" FontSize="14" Margin="0,0,0,10"
                               Text="{DynamicResource Str.Proxies.UngroupedTitle}" VerticalAlignment="Center"/>
                    <DataGrid x:Name="UngroupedGrid" ItemsSource="{Binding UngroupedSources}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Str.Proxies.MenuAddProxy}" Click="AddUngrouped_Click"/>
                                <MenuItem Header="{DynamicResource Str.Common.Edit}" Click="EditUngrouped_Click"/>
                                <MenuItem Header="{DynamicResource Str.Proxies.MenuAssignGroup}" Click="AssignUngrouped_Click"/>
                                <MenuItem Header="{DynamicResource Str.Common.Delete}" Click="DeleteUngrouped_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Display}" Width="*">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColProxy}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding ProxyTypeText}" Width="70">
                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColType}"/></DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Log" Height="24" Padding="10,0" Click="LogForRow_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Groups + detail: two cards, each takes half the height -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Groups -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Heading}" FontSize="14" Margin="0,0,0,10"
                                   Text="{DynamicResource Str.Proxies.GroupsTitle}" VerticalAlignment="Center"/>
                        <DataGrid x:Name="GroupsGrid" ItemsSource="{Binding Groups}" SelectionMode="Single"
                                  SelectedItem="{Binding SelectedGroup}">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource Str.Proxies.MenuAddGroup}" Click="AddGroup_Click"/>
                                    <MenuItem Header="{DynamicResource Str.Common.Edit}" Click="EditGroup_Click"/>
                                    <MenuItem Header="{DynamicResource Str.Proxies.MenuGroupUp}" Click="GroupUp_Click"/>
                                    <MenuItem Header="{DynamicResource Str.Proxies.MenuGroupDown}" Click="GroupDown_Click"/>
                                    <MenuItem Header="{DynamicResource Str.Common.Delete}" Click="DeleteGroup_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColName}"/></DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Priority}" Width="60">
                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColPriority}"/></DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Width="90">
                                    <DataGridTemplateColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColMatch}"/></DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Height="26" SelectedItem="{Binding MatchMode, Mode=OneWay}"
                                                      SelectionChanged="MatchMode_Changed"
                                                      ItemsSource="{Binding DataContext.MatchModeValues, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding Summary}" Width="110">
                                    <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColContent}"/></DataGridTextColumn.Header>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <!-- Detail (filters + group proxies) -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" FontSize="14" Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Heading}">
                                    <Setter Property="Text" Value="{Binding SelectedGroup.Name, StringFormat='Group: {0}'}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedGroup}" Value="{x:Null}">
                                            <Setter Property="Text" Value="{DynamicResource Str.Proxies.SelectGroup}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TabControl>
                            <TabItem Header="{DynamicResource Str.Proxies.TabFilters}">
                                <DockPanel Margin="0,8,0,0">
                                    <DataGrid x:Name="FiltersGrid" ItemsSource="{Binding Filters}" SelectionMode="Single">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{DynamicResource Str.Proxies.MenuAddFilter}" Click="AddFilter_Click"/>
                                                <MenuItem Header="{DynamicResource Str.Common.Edit}" Click="EditFilter_Click"/>
                                                <MenuItem Header="{DynamicResource Str.Common.Delete}" Click="DeleteFilter_Click"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding TypeText}" Width="Auto">
                                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColType}"/></DataGridTextColumn.Header>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Binding="{Binding Display}" Width="*">
                                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColFilter}"/></DataGridTextColumn.Header>
                                            </DataGridTextColumn>
                                            <DataGridTemplateColumn Header="NOT" Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsNot, Mode=OneWay}" Click="FilterIsNot_Click" HorizontalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="{DynamicResource Str.Proxies.TabGroupProxies}">
                                <DockPanel Margin="0,8,0,0">
                                    <DataGrid x:Name="GroupSourcesGrid" ItemsSource="{Binding GroupSources}">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{DynamicResource Str.Proxies.MenuAddProxy}" Click="AddGroupSource_Click"/>
                                                <MenuItem Header="{DynamicResource Str.Proxies.MenuRemoveFromGroup}" Click="UngroupSource_Click"/>
                                                <MenuItem Header="{DynamicResource Str.Common.Delete}" Click="DeleteGroupSource_Click"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Display}" Width="*">
                                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColProxy}"/></DataGridTextColumn.Header>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Binding="{Binding ProxyTypeText}" Width="70">
                                                <DataGridTextColumn.Header><TextBlock Text="{DynamicResource Str.Proxies.ColType}"/></DataGridTextColumn.Header>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
